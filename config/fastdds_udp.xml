<?xml version="1.0" encoding="UTF-8"?>
<!--
  Fast-DDS profile that DISABLES the shared-memory (SHM) transport and forces
  UDPv4 for all participants.

  Why: when Autoware brings up ~100 nodes at once inside one container, several
  component_container processes race to lock the same SHM segment and fail with:
      [RTPS_TRANSPORT_SHM Error] Failed init_port fastrtps_port7411:
      open_and_lock_file failed
  The running nodes tolerate it, but ANY later-joining client (ros2 topic echo /
  hz / tf2_echo used for diagnostics) cannot join the DDS graph -> every query
  returns "topic does not appear to be published yet" (false negative).

  Forcing UDPv4 removes the SHM lock entirely. On localhost the throughput cost
  is negligible for this workload and diagnostics work reliably.

  Usage (inside the container, before ros2 launch AND for any ros2 CLI query):
      export FASTRTPS_DEFAULT_PROFILES_FILE=/path/to/fastdds_udp.xml
-->
<dds xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
  <profiles>
    <transport_descriptors>
      <transport_descriptor>
        <transport_id>udp_only</transport_id>
        <type>UDPv4</type>
        <!-- Large transient_local samples (the lanelet2 vector map: ~8 MB on
             Town04 vs 0.5 MB on Town01) fragment into many UDP datagrams. With
             the default ~64 KB socket buffers the receiver drops fragments on
             late join -> behavior_path_planner hangs on "waiting for map" and
             never produces a trajectory (Town01 is small enough to slip through).
             Big socket buffers let the OS hold a whole fragmented sample.
             sendBufferSize/receiveBufferSize are SO_SND/RCVBUF, capped by
             net.core.wmem_max/rmem_max -> raised on the host in the run script. -->
        <maxMessageSize>65500</maxMessageSize>
        <sendBufferSize>33554432</sendBufferSize>
        <receiveBufferSize>33554432</receiveBufferSize>
      </transport_descriptor>
    </transport_descriptors>
    <participant profile_name="udp_participant" is_default_profile="true">
      <rtps>
        <userTransports>
          <transport_id>udp_only</transport_id>
        </userTransports>
        <useBuiltinTransports>false</useBuiltinTransports>
      </rtps>
    </participant>
  </profiles>
</dds>
